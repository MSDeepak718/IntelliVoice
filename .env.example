# ============================================================
# IntelliVoice — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.

# ---------- General ----------
APP_NAME=IntelliVoice
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---------- MongoDB ----------
MONGODB_URI=mongodb://intellivoice:intellivoice@localhost:27017
MONGODB_DB_NAME=intellivoice

# ---------- HuggingFace ----------
HF_TOKEN=
HF_HOME=./models

# ---------- GPU ----------
CUDA_VISIBLE_DEVICES=0
GPU_MEMORY_FRACTION=0.95

# ---------- Model Paths (auto-downloaded if empty) ----------
SILERO_VAD_MODEL_PATH=
DEEPFILTERNET_MODEL_PATH=
XLSR_MODEL_PATH=
QWEN_AUDIO_MODEL_PATH=
EMOTION2VEC_MODEL_PATH=
WAVLM_MODEL_PATH=
QWEN3_MODEL_PATH=
COSYVOICE_MODEL_PATH=
HIFIGAN_MODEL_PATH=

# ---------- Audio ----------
SAMPLE_RATE=16000
CHUNK_SIZE_MS=30
VAD_THRESHOLD=0.5

# ---------- LLM ----------
MAX_NEW_TOKENS=512
TEMPERATURE=0.7
TOP_P=0.9
