# ============================================================
# IntelliVoice — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.

# ---------- General ----------
APP_NAME=IntelliVoice
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---------- HuggingFace ----------
HF_TOKEN=
HF_HOME=./models

# ---------- GPU ----------
CUDA_VISIBLE_DEVICES=0
GPU_MEMORY_FRACTION=0.92

# ---------- Audio ----------
SAMPLE_RATE=16000
CHUNK_SIZE_MS=30
# VAD: lowered to 0.35 to pick up soft / accented speech.
VAD_THRESHOLD=0.35
VAD_MIN_SPEECH_MS=80
VAD_MIN_SILENCE_MS=300
VAD_SPEECH_PAD_MS=120
# AGC target RMS dBFS before VAD sees the audio.
AGC_TARGET_DB=-20.0
MAX_AUDIO_LENGTH_S=30

# ---------- LLM ----------
MAX_NEW_TOKENS=150
TEMPERATURE=0.7
TOP_P=0.9
