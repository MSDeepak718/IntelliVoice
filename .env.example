# ============================================================
# IntelliVoice — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.

# ---------- General ----------
APP_NAME=IntelliVoice
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---------- MongoDB ----------
MONGODB_URI=mongodb://intellivoice:intellivoice@localhost:27017
MONGODB_DB_NAME=intellivoice

# ---------- Qdrant (vector store) ----------
# Set QDRANT_IN_MEMORY=false to use the docker service instead.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=intellivoice_rag
QDRANT_IN_MEMORY=true
QDRANT_VECTOR_SIZE=1024

# ---------- HuggingFace ----------
HF_TOKEN=
HF_HOME=./models

# ---------- GPU ----------
CUDA_VISIBLE_DEVICES=0
GPU_MEMORY_FRACTION=0.92

# ---------- Model Paths (auto-downloaded if empty) ----------
SILERO_VAD_MODEL_PATH=
DEEPFILTERNET_MODEL_PATH=
WHISPER_MODEL_PATH=
SENSEVOICE_MODEL_PATH=
ECAPA_TDNN_MODEL_PATH=
QWEN3_14B_MODEL_PATH=
COSYVOICE2_MODEL_PATH=

# ---------- Audio ----------
SAMPLE_RATE=16000
CHUNK_SIZE_MS=30
# VAD: lowered to 0.35 to pick up soft / accented speech.
VAD_THRESHOLD=0.35
VAD_MIN_SPEECH_MS=80
VAD_MIN_SILENCE_MS=300
VAD_SPEECH_PAD_MS=120
# AGC target RMS dBFS before VAD sees the audio.
AGC_TARGET_DB=-20.0
MAX_AUDIO_LENGTH_S=30

# ---------- LLM ----------
MAX_NEW_TOKENS=512
TEMPERATURE=0.7
TOP_P=0.9

# ---------- RAG ----------
RAG_TOP_K=5
RAG_MIN_SCORE=0.35
RAG_USE_RERANKER=false

# ---------- VRAM / Phase manager ----------
ENABLE_PHASE_SWAPPING=true
UNLOAD_XLSR_AFTER_ASR=true
PRELOAD_NEXT_PHASE=false
